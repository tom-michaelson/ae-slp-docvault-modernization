{
  "key": "set-basket-item-quantities",
  "name": "Set basket item quantities",
  "type": "api-endpoint",
  "domain": "basket",
  "legacyEntryPoint": "Microsoft.eShopWeb.ApplicationCore.Services.BasketService.SetQuantities",
  "legacyLocation": "src/ApplicationCore/Services/BasketService.cs:47",
  "legacyWebHandler": "Microsoft.eShopWeb.Web.Pages.Basket.IndexModel.OnPostUpdate",
  "targetRestContract": {
    "method": "PUT",
    "path": "/api/baskets/{basketId}/items",
    "requestModel": {
      "quantities": "Map<basketItemId: string, quantity: int>"
    },
    "responseModel": "BasketResponse",
    "errorModes": [
      {"status": 404, "when": "basketId not found"},
      {"status": 400, "when": "any quantity < 0"}
    ]
  },
  "usedByUiFeatures": ["basket-view-page"],
  "notes": [
    "Legacy returns Ardalis.Result<Basket>.NotFound() when basketId is missing — surfaces as 404 in the target API.",
    "Zero-quantity items are removed (Basket.RemoveEmptyItems)."
  ]
}
