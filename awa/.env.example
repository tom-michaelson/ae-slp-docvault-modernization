#------------------------------#
#            System            #
#------------------------------#
PYTHONPYCACHEPREFIX="./.cache/pycache"
# DEBUG_MODE=true
# HOME_DIR="/specified/as/absolute/path"

#------------------------------#
#     Service Configuration    #
#------------------------------#
# Temporal
# TEMPORAL_UI_HOST=localhost
# TEMPORAL_UI_PORT=8002
# TEMPORAL_SERVER_HOST=localhost
# TEMPORAL_SERVER_PORT=7233
# TEMPORAL_METRICS_PORT=8004

# UI
# AWA_UI_HOST=localhost
# AWA_UI_PORT=8000
# AWA_API_HOST=localhost
# AWA_API_PORT=8001

#------------------------------#
#       Temporal - Docker      #
#------------------------------#
# TEMPORAL_VERSION=1.27.2
# TEMPORAL_ADMINTOOLS_VERSION=1.27.2-tctl-1.18.2-cli-1.3.0
# TEMPORAL_UI_VERSION=2.34.0
# POSTGRESQL_VERSION=16
# POSTGRES_PASSWORD=temporal
# POSTGRES_USER=temporal
# POSTGRES_DEFAULT_PORT=5432

#------------------------------#
#             Auth             #
#------------------------------#
# PUBLIC_AUTH_MODE=cognito
# PUBLIC_DOCS_ONLY=false

## Cognito
# AUTH_COGNITO_CLIENT_ID=
# AUTH_COGNITO_CLIENT_SECRET=
# AUTH_COGNITO_ISSUER=

## Astro Auth (Auth.js)
# AUTH_SECRET=

## Service-to-Service Authentication
# AWA_SERVICE_TOKEN=your_secure_service_token

#------------------------------#
#         LLM Providers        #
#------------------------------#
# LITE_LLM_API_KEY="sk-awa"
# AZURE_OPENAI_API_KEY=your_key
# OPENAI_API_KEY=your_key
# GITHUB_COPILOT_API_KEY=your_key
# ANTHROPIC_API_KEY=your_key

# Google Vertex AI (will automatically use gcloud auth, metadata server, or service account file)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

#------------------------------#
#           LANGFUSE           #
#------------------------------#
# LANGFUSE_SECRET_KEY="the_secret_key"
# LANGFUSE_PUBLIC_KEY="the_public_key"

#------------------------------#
#           AWS                #
#------------------------------#
# AWS_REGION=us-east-1
# AWS_PROFILE=your_profile
# AWS_ACCESS_KEY_ID=your_access_key_id
# AWS_SECRET_ACCESS_KEY=your_secret_access_key

#------------------------------#
#             Jira             #
#------------------------------#
# JIRA_API_KEY=your_key

#------------------------------#
#            Logging           #
#------------------------------#
# Overall log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# LOG_LEVEL=DEBUG

# Log directory path (defaults to 'logs' in the project root)
# LOG_PATH=logs
# LOG_WORKFLOW_DIR=logs/workflows

# File rotation settings (when to rotate log files)
# LOG_FILE_ROTATION_SIZE=1 MB

# Enable/disable logging outputs
# LOG_CONSOLE_ENABLED=true
# LOG_FILE_ENABLED=true

# Structured JSON logging
# LOG_ENABLE_JSON=true


#------------------------------#
#     Claude Code + Bedrock    #
#------------------------------#
# CLAUDE_CODE_USE_BEDROCK=1
# ANTHROPIC_MODEL='us.anthropic.claude-sonnet-4-20250514-v1:0'
# ANTHROPIC_SMALL_FAST_MODEL='us.anthropic.claude-3-5-haiku-20241022-v1:0'
# DISABLE_PROMPT_CACHING=1

#------------------------------#
#       GitHub                 #
#------------------------------#
# GITHUB_PERSONAL_ACCESS_TOKEN=your_token

#------------------------------#
#            SDK               #
#------------------------------#
# UV_KEYRING_PROVIDER=subprocess
# UV_INDEX_PRIVATE_REGISTRY_USERNAME=aws
