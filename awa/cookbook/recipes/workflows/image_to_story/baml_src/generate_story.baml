class GenerateStoryRequest {
  screenshot image
}

class GenerateStoryResponse {
  title string
  description string @alias("story") @description("Full story content, in structured markdown.")
}

function GenerateStory(request: GenerateStoryRequest) -> GenerateStoryResponse {
  client "openai/gpt-4.1"
  prompt #"""
    {{ _.role("system") }}

    You are a senior product manager tasked with creating a comprehensive user story for building a new web page based on a Figma design.

    Analyze the provided Figma screenshot.

    Based on your analysis, generate a user story that includes:
    1. A clear, concise title for the work.
    2. An overview describing the purpose and main sections of the page.
    3. A high-level implementation plan, breaking down the work into logical steps (e.g., "Set up page skeleton," "Build header component," "Implement main content area").
    4. A detailed list of acceptance criteria that describe the expected behavior of the work, in Gherkin format (do not use actual ``` code blocks).

    {{ _.role("user") }}
    <screenshot>
    {{ request.screenshot }}
    </screenshot>

    # Response
    {{ ctx.output_format }}
  """#
}

test TestGenerateStory {
  functions [GenerateStory]
  args {
    request {
      screenshot {
        base64 #""#
        media_type "image/png"
      }
    }
  }
}
