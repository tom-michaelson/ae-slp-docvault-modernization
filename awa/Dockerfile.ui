# Stage 1: Generate TypeScript models
# Use a multi-stage build to generate TypeScript models without needing to install Python in the UI build stage
FROM python:3.12-slim AS modelgen
WORKDIR /app

# Install pnpm and Node.js dependencies
RUN apt-get update && apt-get install -y build-essential npm && npm install -g pnpm

# Copy and install Python dependencies
COPY pyproject.toml uv.lock ./

RUN apt-get update && apt-get install -y \
    gcc \
    g++ \
    make \
    python3-dev \
    && rm -rf /var/lib/apt/lists/*

RUN pip install uv
RUN uv sync

# Copy only what's needed for model generation
COPY scripts/generate_typescript_models.py scripts/
COPY awa/core awa/core

# Copy package.json and pnpm-lock.yaml for json-schema-to-typescript
COPY package.json pnpm-lock.yaml ./
RUN pnpm install --frozen-lockfile

# Run the script
COPY ui/src/types ui/src/types
RUN uv run -m scripts.generate_typescript_models

# Stage 2: UI build
FROM node:22-slim AS builder

# Set environment variables
ENV NODE_ENV=production
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV AWA_UI_PORT=8000

# Set PUBLIC environment variables for build time (these get baked into the built app)
ARG PUBLIC_AUTH_MODE=none
ARG PUBLIC_DOCS_ONLY=false
ARG PUBLIC_AUTH_TRUST_HOST=true

# Install system dependencies
RUN apt-get update && apt-get install -y \
    curl \
    git \
    && rm -rf /var/lib/apt/lists/*

# Install pnpm
RUN npm install -g pnpm

# Set working directory
WORKDIR /app

# Copy package files
COPY ui/package.json ui/pnpm-lock.yaml ./ui/
COPY package.json pnpm-lock.yaml ./

# Install dependencies - combine to avoid duplicate layers
RUN cd /app/ui && pnpm install --frozen-lockfile --prefer-offline --silent && \
    cd /app && pnpm install --frozen-lockfile --prefer-offline --silent

# Copy all root files
COPY . ./

# Copy generated TypeScript models from modelgen stage
COPY --from=modelgen /app/ui/src/types/ ui/src/types/

ENV CI=true
ENV PNPM_CI=true
RUN pnpm run docs:build

# Remove any docs from public directory to force authentication
RUN rm -rf ui/public/docs

# Build the application
RUN pnpm run ui:build


# Stage 3: Runtime
FROM node:22-slim AS runtime

# Set environment variables
ENV NODE_ENV=production
ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"
ENV AWA_UI_PORT=8000

# Install minimal runtime dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    && rm -rf /var/lib/apt/lists/* \
    && npm install -g pnpm

# Create non-root user first
RUN useradd --create-home --shell /bin/bash awa-ui

# Set working directory
WORKDIR /app

# Copy built application and dependencies from builder stage
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/dist ./ui/dist
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/src ./ui/src
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/package.json ./ui/package.json
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/pnpm-lock.yaml ./ui/pnpm-lock.yaml
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/node_modules ./ui/node_modules
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/astro.config.mjs ./ui/astro.config.mjs
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/tailwind.config.mjs ./ui/tailwind.config.mjs
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/postcss.config.mjs ./ui/postcss.config.mjs
COPY --from=builder --chown=awa-ui:awa-ui /app/package.json ./package.json
COPY --from=builder --chown=awa-ui:awa-ui /app/pnpm-lock.yaml ./pnpm-lock.yaml
COPY --from=builder --chown=awa-ui:awa-ui /app/node_modules ./node_modules
COPY --from=builder --chown=awa-ui:awa-ui /app/ui/docs-content ./ui/docs-content

# Copy entry point script
COPY --chown=awa-ui:awa-ui scripts/docker-entrypoint-ui.sh ./

# Debug: Check what we copied to runtime
RUN echo "=== DEBUG: Runtime stage - checking copied docs ===" && \
    ls -la docs/ || echo "No docs directory found" && \
    echo "=== Runtime stage - checking if docs has files ===" && \
    find docs/ -type f | head -10 || echo "No files found in docs"

# Switch to non-root user
USER awa-ui

# Expose port
EXPOSE $AWA_UI_PORT

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD curl -f http://localhost:$AWA_UI_PORT || exit 1

# Default command
ENTRYPOINT ["./docker-entrypoint-ui.sh"]
