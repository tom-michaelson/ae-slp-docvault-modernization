{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup Repo",
      "type": "shell",
      "command": "make install",
      "runOptions": {
        "instanceLimit": 1
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    },
    {
      "label": "Generate BAML Client",
      "type": "shell",
      "command": "uv run -m scripts.generate_baml_client",
      "runOptions": {
        "runOn": "folderOpen",
        "instanceLimit": 1
      },
      "group": "build",
      "presentation": {
        "echo": true,
        "reveal": "silent",
        "focus": false,
        "panel": "shared",
        "showReuseMessage": false,
        "clear": false
      },
      "problemMatcher": []
    }
  ]
}
