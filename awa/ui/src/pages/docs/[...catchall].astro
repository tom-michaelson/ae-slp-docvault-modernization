---
export const prerender = false;
import fs from "fs/promises";
import path from "path";
import { fileURLToPath } from "url";
import mime from "mime";

const catchall = Astro.params.catchall
  ? Array.isArray(Astro.params.catchall)
    ? Astro.params.catchall.join("/")
    : Astro.params.catchall
  : "";

// Get the correct path to docs content
const docsDistPath = path.resolve(process.cwd(), "docs-content");
let filePath = path.join(docsDistPath, catchall || "index.html");

// Check if path exists and handle directories
try {
  const stats = await fs.stat(filePath);
  // If it's a directory, append index.html
  if (stats.isDirectory()) {
    filePath = path.join(filePath, "index.html");
    // Verify the index.html exists
    await fs.access(filePath);
  }
} catch {
  return new Response("Not found", { status: 404 });
}

// Get file extension and MIME type
const ext = path.extname(filePath).toLowerCase();
const mimeType = mime.getType(filePath) || "text/plain";

// For non-HTML files, serve them directly with proper MIME type
if (ext !== ".html" && ext !== "") {
  const fileContent = await fs.readFile(filePath);
  return new Response(fileContent, {
    headers: {
      "Content-Type": mimeType,
      "Cache-Control": "public, max-age=31536000", // 1 year cache for assets
    },
  });
}

// For HTML files, serve them in the component
let html = "";
try {
  html = await fs.readFile(filePath, "utf-8");
} catch (e) {
  html = `<h1>Not found</h1><p>Path: ${filePath}</p><p>Error: ${e.message}</p>`;
}
---

<div class="docs-content" set:html={html} />
