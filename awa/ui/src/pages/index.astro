---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
import LoginButton from "../components/LoginButton";
import { getSession } from "auth-astro/server";
import { getEffectiveSession } from "../utils/auth";

const actualSession = await getSession(Astro.request);
const session = getEffectiveSession(actualSession);
const authMode = import.meta.env.PUBLIC_AUTH_MODE || "none";
const docsOnly = import.meta.env.PUBLIC_DOCS_ONLY === "true";

if (session) {
  // Redirect based on auth mode and docs-only flag
  const redirectPath = authMode === "cognito" && docsOnly ? "/docs" : "/runs";
  return Astro.redirect(redirectPath);
}
---

<Layout>
  <div class="flex flex-col items-center py-8 px-4 min-h-full">
    <section class="mb-8 text-center max-w-xl">
      <h1 class="text-3xl font-bold mb-4">
        Welcome to the <br />Slalom Agentic Workflow Accelerator<br />(AWA)
      </h1>
      <div
        class="bg-gray-900 rounded-xl shadow-lg border border-gray-700 max-w-2xl mx-auto mb-8"
      >
        <div class="relative flex items-center px-4 py-2">
          <div class="flex items-center space-x-2">
            <span class="w-3 h-3 rounded-full bg-red-500 inline-block"></span>
            <span class="w-3 h-3 rounded-full bg-yellow-400 inline-block"
            ></span>
            <span class="w-3 h-3 rounded-full bg-green-500 inline-block"></span>
          </div>
          <span
            class="absolute left-1/2 transform -translate-x-1/2 text-gray-300 font-bold text-sm select-none"
            >awa</span
          >
        </div>
        <pre
          class="bg-gray-900 text-green-200 font-mono rounded-b-lg p-4 text-sm leading-tight border-t border-gray-700 shadow-md whitespace-pre mt-0">
+-------------------------------------------+
|                                           |
|      /\\      \            /      /\\     |
|     /  \\      \    /\    /      /  \\    |
|    /....\\      \  /  \  /      /....\\   |
|   /  ..  \\      \/    \/      /  ..  \\  |
|  /__/  \__\\ Agentic Workflow /__/  \__\\ |
|                Accelerator                |
+-------------------------------------------+
				</pre>
      </div>
    </section>
    <div class="w-full max-w-5xl mb-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div
          class="bg-white rounded-lg shadow p-6 text-center border border-gray-200"
        >
          <h2 class="text-xl font-semibold mb-2">Easy</h2>
          <p class="text-gray-700 text-base">
            Problem solving with agentic workflows requires a new architectural
            mindset. The tooling to support this work should be as simple to use
            as possible. AWA is <strong
              >easy to understand, quick to get started with, and simple to use</strong
            >.
          </p>
        </div>
        <div
          class="bg-white rounded-lg shadow p-6 text-center border border-gray-200"
        >
          <h2 class="text-xl font-semibold mb-2">Compatible</h2>
          <p class="text-gray-700 text-base">
            Our clients have a wide array of environments and constraints. Our
            projects have a wide range of requirements and use cases. AWA is <strong
              >maximally compatible to meet (almost) any need</strong
            >.
          </p>
        </div>
        <div
          class="bg-white rounded-lg shadow p-6 text-center border border-gray-200"
        >
          <h2 class="text-xl font-semibold mb-2">Useful</h2>
          <p class="text-gray-700 text-base">
            Accelerator means <em>acceleration</em>. Ease and compatibility mean
            nothing if the tool is not useful. AWA is <strong
              >powerful out of the box, with a large set of reusable components,
              ready-to-demo examples, and a clear path from demo to production</strong
            >.
          </p>
        </div>
      </div>
    </div>
    <div class="mb-8">
      <LoginButton client:load authMode={authMode} />
    </div>
  </div>
</Layout>
