---
import "../styles/global.css";
import LoginButton from "../components/LoginButton";
export interface Props {
  userName?: string;
}
const { userName } = Astro.props;
const authMode = import.meta.env.PUBLIC_AUTH_MODE || "none";
const docsOnly = import.meta.env.PUBLIC_DOCS_ONLY === "true";

// Get service URLs from environment variables with fallbacks
const awaApiHost = import.meta.env.AWA_API_HOST || "localhost";
const awaApiPort = import.meta.env.AWA_API_PORT || "8001";
const temporalUiHost = import.meta.env.TEMPORAL_UI_HOST || "localhost";
const temporalUiPort = import.meta.env.TEMPORAL_UI_PORT || "8002";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon/favicon.svg" />
    <link
      rel="icon"
      type="image/png"
      sizes="96x96"
      href="/favicon/favicon-96x96.png"
    />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/favicon/apple-touch-icon.png"
    />
    <link rel="manifest" href="/favicon/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>Slalom AWA</title>
  </head>
  <body class="flex flex-col min-h-screen bg-gray-50">
    <header
      class="w-full bg-blue-700 text-white flex items-center justify-between px-6 py-3 shadow-md"
    >
      <div class="flex items-center gap-3">
        <img src="/images/AWA Logo.svg" alt="AWA Logo" class="h-8 w-auto" />
        <div class="flex flex-col">
          <!-- <span class="font-bold text-lg leading-tight">AWA</span> -->
          <span class="text-xs text-blue-100 leading-tight">by Slalom</span>
        </div>
      </div>
      <nav class="flex items-center gap-6">
        {
          userName && typeof userName === "string" && userName.trim() ? (
            <>
              <div class="flex items-center gap-x-6">
                {!(authMode === "cognito" && docsOnly) && (
                  <div class="relative">
                    <a
                      href="/runs"
                      class="hover:underline text-white text-base font-medium"
                    >
                      Runs
                    </a>
                  </div>
                )}
                <div class="relative">
                  <a
                    href="/docs"
                    class="hover:underline text-white text-base font-medium"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Docs
                  </a>
                </div>
                <div class="relative">
                  <button
                    class="flex items-center gap-2 py-2 bg-transparent text-white text-base font-medium hover:underline outline-none ring-0 focus:outline-none focus:ring-0"
                    id="services-menu-button"
                    type="button"
                  >
                    Services
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-4 w-4 text-white"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </button>
                  <div
                    class="hidden absolute right-0 mt-2 w-48 bg-white text-black rounded shadow-lg z-50 flex-col"
                    id="services-menu-dropdown"
                  >
                    <a
                      href={`http://${awaApiHost}:${awaApiPort}/docs`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-full text-left px-4 py-2 hover:bg-blue-100 border-b border-gray-200"
                    >
                      AWA API
                    </a>
                    <a
                      href={`http://${temporalUiHost}:${temporalUiPort}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="w-full text-left px-4 py-2 hover:bg-blue-100"
                    >
                      Temporal UI
                    </a>
                  </div>
                </div>
              </div>
              <div class="relative">
                <button
                  class="flex items-center gap-3 px-4 py-2 bg-transparent text-white text-lg outline-none ring-0 focus:outline-none focus:ring-0"
                  title={userName}
                  id="user-menu-button"
                  type="button"
                  style="min-width: 0;"
                >
                  <span class="flex items-center gap-3">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-7 w-7 text-white"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <circle
                        cx="12"
                        cy="8"
                        r="4"
                        stroke="currentColor"
                        stroke-width="2"
                        fill="none"
                      />
                      <path
                        stroke="currentColor"
                        stroke-width="2"
                        d="M4 20c0-4 4-6 8-6s8 2 8 6"
                        fill="none"
                      />
                    </svg>
                    <span
                      class="whitespace-nowrap text-base font-normal tracking-wide"
                      style="letter-spacing:0.04em;"
                    >
                      {userName}
                    </span>
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      class="h-5 w-5 ml-1 text-white"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M19 9l-7 7-7-7"
                      />
                    </svg>
                  </span>
                </button>
                <div
                  class="hidden absolute right-0 mt-2 w-32 bg-white text-black rounded shadow-lg z-50 flex-col"
                  id="user-menu-dropdown"
                >
                  <button
                    class="w-full text-left px-4 py-2 hover:bg-blue-100 rounded-b"
                    id="logout-btn"
                    type="button"
                  >
                    Log Out
                  </button>
                </div>
              </div>
            </>
          ) : (
            <LoginButton
              variant="link"
              client:only="react"
              authMode={authMode}
            />
          )
        }
      </nav>
    </header>
    <main class="flex-1 min-h-0 flex flex-col overflow-auto">
      <slot />
    </main>
    <footer
      class="w-full bg-gray-800 text-gray-100 text-center py-3 text-sm mt-auto flex-shrink-0"
    >
      © Slalom, Inc. All rights reserved. | Slalom InfoSec: Review Pending
    </footer>
  </body>
</html>

<style>
  html,
  body {
    margin: 0;
    width: 100%;
    height: 100%;
    min-height: 100vh;
  }
</style>

<script>
  if (typeof window !== "undefined") {
    const userMenuBtn = document.getElementById("user-menu-button");
    const dropdown = document.getElementById("user-menu-dropdown");
    if (userMenuBtn && dropdown) {
      userMenuBtn.addEventListener("click", () => {
        dropdown.classList.toggle("flex");
        dropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        const target = e.target as Element;
        if (!userMenuBtn.contains(target) && !dropdown.contains(target)) {
          dropdown.classList.add("hidden");
          dropdown.classList.remove("flex");
        }
      });
    }

    const servicesMenuBtn = document.getElementById("services-menu-button");
    const servicesDropdown = document.getElementById("services-menu-dropdown");
    if (servicesMenuBtn && servicesDropdown) {
      servicesMenuBtn.addEventListener("click", () => {
        servicesDropdown.classList.toggle("flex");
        servicesDropdown.classList.toggle("hidden");
      });
      document.addEventListener("click", (e) => {
        const target = e.target as Element;
        if (
          !servicesMenuBtn.contains(target) &&
          !servicesDropdown.contains(target)
        ) {
          servicesDropdown.classList.add("hidden");
          servicesDropdown.classList.remove("flex");
        }
      });
    }

    const logoutBtn = document.getElementById("logout-btn");
    if (logoutBtn) {
      logoutBtn.addEventListener("click", async () => {
        const { signOut } = await import("auth-astro/client");
        await signOut();
        window.location.href = "/";
      });
    }
  }
</script>
