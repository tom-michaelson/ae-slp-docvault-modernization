{
  "template-version": "2.0",
  "source-locations": [
    {
      "source-id": "s3-source",
      "source-type": "s3",
      "properties": {
        "s3-bucket": "<s3-bucket-name>",
        "s3-key-prefix": "carddemo"
      }
    }
  ],
  "definition": {
    "listeners": [
      {
        "port": 7000,
        "type": "tn3270"
      }
    ],
    "dataset-location": {
      "db-locations": [
        {
          "name": "db1",
          "secret-manager-arn": "arn:aws:secretsmanager:us-east-1:111111111111:secret:M2DatabaseSecret-N8KrYzhMpnCg-oZy0Az"
        }
      ]
    },
    "batch-settings": {
      "initiators": [
        {
          "classes": [
            "A",
            "B"
          ],
          "description": "initiator...."
        }
      ],
      "jcl-file-location": "${s3-source}/catalog/jcl"
    },
    "cics-settings": {
      "binary-file-location": "${s3-source}/loadlib",
      "csd-file-location": "${s3-source}/rdef",
      "system-initialization-table": "CARDSIT"
    },
    "xa-resources": [
      {
        "name": "XASQL",
        "secret-manager-arn": "arn:aws:secretsmanager:us-east-1:111111111111:secret:M2DatabaseSecret-N8KrYzhMpnCg-oZy0Az",
        "module": "${s3-source}/xa/ESPGSQLXA64.so"
      }
    ]
  }
}
